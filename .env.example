# NewMCP Configuration

# Server
PORT=3000
GIN_MODE=debug

# Database
DB_TYPE=sqlite
DB_PATH=./data/newmcp.db
# DB_TYPE=mysql
# SQL_DSN=newmcp:password@tcp(mysql:3306)/newmcp?charset=utf8mb4&parseTime=True

# Redis (optional)
# REDIS_CONN_STRING=redis://localhost:6379

# Security
SESSION_SECRET=change-me-to-a-random-string
CRYPTO_SECRET=change-me-to-a-random-string

# Log level: debug, info, warn, error
LOG_LEVEL=info
